<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
https://raw.githubusercontent.com/Gethe/wow-ui-source/live/Interface/AddOns/Blizzard_SharedXML/UI.xsd">
    <Frame name="GuidePostSettingsPanel" parent="UIParent" inherits="BasicFrameTemplateWithInset" mixin="GuidePostSettingsPanelMixin" frameStrata="DIALOG" movable="true" enableMouse="true" registerForDrag="LeftButton" hidden="true">
        <Size x="310" y="240"/>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="ScopeHeader" inherits="GameFontNormal" justifyH="LEFT" text="Achievement Scope">
                    <Anchors>
                        <Anchor point="TOPLEFT" x="15" y="-35"/>
                        <Anchor point="TOPRIGHT" x="-15" y="-35"/>
                    </Anchors>
                </FontString>
                <FontString parentKey="ScopeDesc" inherits="GameFontNormalSmall" text="Controls which achievements are shown in the list.">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.ScopeHeader" relativePoint="BOTTOMLEFT" y="-5"/>
                    </Anchors>
                    <Color r="0.67" g="0.67" b="0.67"/>
                </FontString>
                <FontString parentKey="AutoHeader" inherits="GameFontNormal" justifyH="LEFT" text="Automation">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.ScopeHeader" relativePoint="BOTTOMLEFT" y="-130"/>
                        <Anchor point="TOPRIGHT" relativeKey="$parent.ScopeHeader" relativePoint="BOTTOMRIGHT" y="-130"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="ARTWORK">
                <Texture parentKey="Separator">
                    <Size y="1"/>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.ScopeHeader" relativePoint="BOTTOMLEFT" y="-110"/>
                        <Anchor point="TOPRIGHT" relativeKey="$parent.ScopeHeader" relativePoint="BOTTOMRIGHT" y="-110"/>
                    </Anchors>
                    <Color r="0.3" g="0.3" b="0.3" a="0.8"/>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <CheckButton parentKey="AccountScopeButton" inherits="UIRadioButtonTemplate">
                <Size x="20" y="20"/>
                <KeyValues>
                    <KeyValue key="gpScope" value="account" type="string"/>
                </KeyValues>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.ScopeDesc" relativePoint="BOTTOMLEFT" x="20" y="-10"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <FontString name="$parentText" inherits="GameFontNormalSmall" parentKey="text">
                            <Anchors>
                                <Anchor point="LEFT" relativePoint="RIGHT" x="5" y="0"/>
                            </Anchors>
                            <Color color="WHITE_FONT_COLOR"/>
                        </FontString>
                    </Layer>
                </Layers>
            </CheckButton>
            <CheckButton parentKey="CharacterScopeButton" inherits="UIRadioButtonTemplate">
                <Size x="20" y="20"/>
                <KeyValues>
                    <KeyValue key="gpScope" value="character" type="string"/>
                </KeyValues>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.AccountScopeButton" relativePoint="BOTTOMLEFT" y="-5"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <FontString name="$parentText" inherits="GameFontNormalSmall" parentKey="text">
                            <Anchors>
                                <Anchor point="LEFT" relativePoint="RIGHT" x="5" y="0"/>
                            </Anchors>
                            <Color color="WHITE_FONT_COLOR"/>
                        </FontString>
                    </Layer>
                </Layers>
            </CheckButton>
            <CheckButton parentKey="GuildScopeButton" inherits="UIRadioButtonTemplate">
                <Size x="20" y="20"/>
                <KeyValues>
                    <KeyValue key="gpScope" value="guild" type="string"/>
                </KeyValues>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.CharacterScopeButton" relativePoint="BOTTOMLEFT" y="-5"/>
                </Anchors>
                <Layers>
                    <Layer level="BACKGROUND">
                        <FontString name="$parentText" inherits="GameFontNormalSmall" parentKey="text">
                            <Anchors>
                                <Anchor point="LEFT" relativePoint="RIGHT" x="5" y="0"/>
                            </Anchors>
                            <Color color="WHITE_FONT_COLOR"/>
                        </FontString>
                    </Layer>
                </Layers>
            </CheckButton>
            <CheckButton parentKey="AutoCheck" inherits="UICheckButtonTemplate">
                <Size x="20" y="20"/>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.AutoHeader" relativePoint="BOTTOMLEFT" x="20" y="-10"/>
                </Anchors>
                <Layers>
                    <Layer level="ARTWORK">
                        <FontString name="$parentText" inherits="GameFontNormalSmall" parentKey="Text" text="Auto-scan when entering a new zone">
                            <Anchors>
                                <Anchor point="LEFT" relativePoint="RIGHT" x="-2" y="0"/>
                            </Anchors>
                            <Color color="WHITE_FONT_COLOR"/>
                            <Scripts>
                                <OnLoad function="UICheckButtonFontString_SetParentKeyAlias"/>
                            </Scripts>
                        </FontString>
                    </Layer>
                </Layers>
            </CheckButton>
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad"/>
            <OnDragStart method="OnDragStart"/>
            <OnDragStop method="OnDragStop"/>
        </Scripts>
    </Frame>
</Ui>